# Backup directories
backup-*/
*.backup-*

# Sensitive files (add patterns for any files with secrets)
.config/gh/hosts.yml
.ssh/
.env
.env.*
!.env.example
*.key
*.pem

# Pi: track portable config only; ignore sessions, credentials, caches, and installs
.pi/agent/*
!.pi/agent/settings.json
!.pi/agent/pi-sub-bar-settings.json
!.pi/agent/extensions/
!.pi/agent/extensions/**
!.pi/agent/skills/
!.pi/agent/skills/**
.pi/agent/extensions/**/.env*
.pi/agent/skills/**/.env*
.pi/agent/extensions/**/node_modules/
.pi/agent/skills/**/node_modules/

# Cache and temporary files
.cache/
*.log
*.swp
*.swo
*~
__pycache__/
*.py[cod]

# OS files
.DS_Store
Thumbs.db

# Obsidian files
.config/obsidian/*
!.config/obsidian/user-flags.conf


# Local git worktrees
.worktrees/
